{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/styles.css", "/app.js", "/data/*"]
  },
  "routes": [
    {
      "route": "/",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}